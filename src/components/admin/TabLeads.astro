<div class="admin-tab-panel hidden" data-tab="leads">

  <!-- Filtros -->
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 mb-4">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Buscar</label>
        <input type="text" id="leads-busca" placeholder="Nome, email, WhatsApp..." class="w-full px-3 py-2 border rounded-lg text-sm" />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Tipo de evento</label>
        <select id="leads-tipo" class="w-full px-3 py-2 border rounded-lg text-sm">
          <option value="">Todos</option>
          <option value="Casamento">Casamento</option>
          <option value="Festa">Festa</option>
          <option value="Confraternização">Confraternização</option>
          <option value="Outro">Outro</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">De</label>
        <input type="date" id="leads-de" class="w-full px-3 py-2 border rounded-lg text-sm" />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Até</label>
        <input type="date" id="leads-ate" class="w-full px-3 py-2 border rounded-lg text-sm" />
      </div>
    </div>
    <div class="flex items-center justify-between mt-3">
      <span id="leads-count" class="text-xs text-gray-400"></span>
      <button id="leads-limpar" class="text-xs text-verde hover:underline">Limpar filtros</button>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
          <tr>
            <th class="px-4 py-3 text-left">Nome</th>
            <th class="px-4 py-3 text-left">Email</th>
            <th class="px-4 py-3 text-left">WhatsApp</th>
            <th class="px-4 py-3 text-left">Nascimento</th>
            <th class="px-4 py-3 text-left">Tipo</th>
            <th class="px-4 py-3 text-left">Data Início</th>
            <th class="px-4 py-3 text-left">Data Fim</th>
            <th class="px-4 py-3 text-left">Convidados</th>
            <th class="px-4 py-3 text-left">Mensagem</th>
            <th class="px-4 py-3 text-left">Recebido em</th>
            <th class="px-4 py-3 text-left">Ações</th>
          </tr>
        </thead>
        <tbody id="leads-tbody" class="divide-y divide-gray-100">
          <tr><td colspan="11" class="px-4 py-8 text-center text-gray-400">Carregando...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div id="leads-vazio" class="hidden py-12 text-center">
    <div class="text-5xl mb-4">📋</div>
    <p class="text-gray-400">Nenhum lead recebido.</p>
  </div>
</div>

<script>
  import { db } from '../../lib/supabase.js'
  import { esc } from '../../lib/helpers.js'

  let leads = []

  async function init() {
    try {
      leads = await db.leads.listar()
    } catch {
      leads = []
    }
    render()
  }

  function formatDate(dateStr) {
    if (!dateStr) return '—'
    try {
      const d = new Date(dateStr + (dateStr.length === 10 ? 'T00:00:00' : ''))
      return d.toLocaleDateString('pt-BR')
    } catch {
      return dateStr
    }
  }

  function formatDateTime(dateStr) {
    if (!dateStr) return '—'
    try {
      return new Date(dateStr).toLocaleString('pt-BR')
    } catch {
      return dateStr
    }
  }

  function getFiltered() {
    const busca = document.getElementById('leads-busca').value.toLowerCase()
    const tipo = document.getElementById('leads-tipo').value
    const de = document.getElementById('leads-de').value
    const ate = document.getElementById('leads-ate').value

    return leads.filter(l => {
      if (busca) {
        const texto = [l.nome, l.email, l.whatsapp, l.mensagem].filter(Boolean).join(' ').toLowerCase()
        if (!texto.includes(busca)) return false
      }
      if (tipo && l.tipo_evento !== tipo) return false
      if (de && l.created_at && l.created_at.slice(0, 10) < de) return false
      if (ate && l.created_at && l.created_at.slice(0, 10) > ate) return false
      return true
    })
  }

  function render() {
    const tbody = document.getElementById('leads-tbody')
    const vazio = document.getElementById('leads-vazio')
    const filtered = getFiltered()

    document.getElementById('leads-count').textContent = `${filtered.length} de ${leads.length} lead(s)`

    if (filtered.length === 0) {
      tbody.closest('table').parentElement.parentElement.classList.add('hidden')
      vazio.classList.remove('hidden')
      return
    }

    vazio.classList.add('hidden')
    tbody.closest('table').parentElement.parentElement.classList.remove('hidden')

    tbody.innerHTML = filtered.map(l => `
      <tr class="hover:bg-gray-50">
        <td class="px-4 py-3 font-medium text-gray-900">${esc(l.nome) || '—'}</td>
        <td class="px-4 py-3 text-gray-600">${esc(l.email) || '—'}</td>
        <td class="px-4 py-3 text-gray-600">${esc(l.whatsapp) || '—'}</td>
        <td class="px-4 py-3 text-gray-600">${formatDate(l.data_nascimento)}</td>
        <td class="px-4 py-3 text-gray-600">${esc(l.tipo_evento) || '—'}</td>
        <td class="px-4 py-3 text-gray-600">${formatDate(l.data_inicio)}</td>
        <td class="px-4 py-3 text-gray-600">${formatDate(l.data_fim)}</td>
        <td class="px-4 py-3 text-gray-600">${l.num_convidados || '—'}</td>
        <td class="px-4 py-3 text-gray-600 max-w-xs truncate">${esc(l.mensagem) || '—'}</td>
        <td class="px-4 py-3 text-gray-600">${formatDateTime(l.created_at)}</td>
        <td class="px-4 py-3">
          <button class="lead-del text-red-500 hover:text-red-700 text-xs font-semibold" data-id="${l.id}">Excluir</button>
        </td>
      </tr>
    `).join('')

    document.querySelectorAll('.lead-del').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Excluir este lead?')) return
        try {
          await db.leads.remover(btn.dataset.id)
          leads = leads.filter(l => l.id !== btn.dataset.id)
          render()
          window.showToast('✅ Lead excluído!')
        } catch {
          window.showToast('❌ Erro ao excluir lead', false)
        }
      })
    })
  }

  document.getElementById('leads-busca').addEventListener('input', render)
  document.getElementById('leads-tipo').addEventListener('change', render)
  document.getElementById('leads-de').addEventListener('change', render)
  document.getElementById('leads-ate').addEventListener('change', render)
  document.getElementById('leads-limpar').addEventListener('click', () => {
    document.getElementById('leads-busca').value = ''
    document.getElementById('leads-tipo').value = ''
    document.getElementById('leads-de').value = ''
    document.getElementById('leads-ate').value = ''
    render()
  })

  init()
</script>
