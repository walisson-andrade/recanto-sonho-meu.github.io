<div class="admin-tab-panel hidden" data-tab="precos">

  <!-- Preços por dia da semana -->
  <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 mb-8">
    <h3 class="font-semibold text-verde mb-4">Preço por dia da semana</h3>
    <div id="precos-semana-grid" class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-7 gap-3">
      <div class="skeleton h-20 rounded-lg"></div>
    </div>
    <button id="salvar-precos-btn" class="mt-4 bg-verde text-white px-6 py-2 rounded-lg font-semibold hover:bg-verde-claro transition-colors">
      Salvar preços
    </button>
  </div>

  <!-- Datas especiais -->
  <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold text-verde">Datas especiais</h3>
      <button id="add-data-especial-btn" class="bg-verde text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-verde-claro">
        + Adicionar
      </button>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-left">
          <tr>
            <th class="px-4 py-3 font-medium text-gray-500">Data</th>
            <th class="px-4 py-3 font-medium text-gray-500">Label</th>
            <th class="px-4 py-3 font-medium text-gray-500">Preço</th>
            <th class="px-4 py-3 font-medium text-gray-500">Recorrente</th>
            <th class="px-4 py-3 font-medium text-gray-500">Ações</th>
          </tr>
        </thead>
        <tbody id="datas-especiais-tbody">
          <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">Carregando...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal data especial -->
  <div id="modal-data-especial" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 hidden">
    <div class="bg-white rounded-2xl p-6 max-w-md w-full mx-4 shadow-2xl">
      <h3 class="font-display text-xl font-bold text-verde mb-4">Nova Data Especial</h3>
      <form id="form-data-especial" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Data</label>
          <input type="date" id="de-data" required class="w-full min-w-0 px-3 py-2 border rounded-lg box-border" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Label</label>
          <input type="text" id="de-label" required class="w-full min-w-0 px-3 py-2 border rounded-lg box-border" placeholder="Ex: Réveillon" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Preço (R$)</label>
          <input type="number" id="de-preco" required step="0.01" class="w-full min-w-0 px-3 py-2 border rounded-lg box-border" />
        </div>
        <label class="flex items-center gap-2">
          <input type="checkbox" id="de-recorrente" class="accent-verde" />
          <span class="text-sm text-gray-600">Recorrente (repete todo ano)</span>
        </label>
        <div class="flex gap-3 pt-2">
          <button type="button" id="modal-de-cancel" class="flex-1 py-2 rounded-lg border border-gray-300 hover:bg-gray-50">Cancelar</button>
          <button type="submit" class="flex-1 py-2 rounded-lg bg-verde text-white font-semibold hover:bg-verde-claro">Salvar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  import { db } from '../../lib/supabase.js'
  import { formatarPreco, formatarData } from '../../lib/helpers.js'

  const DIAS = ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado']

  async function loadPrecos() {
    try {
      const precos = await db.precos.listar()
      const grid = document.getElementById('precos-semana-grid')
      grid.innerHTML = precos.map(p => `
        <div class="text-center">
          <label class="block text-xs font-medium text-gray-500 mb-1">${DIAS[p.dia_semana]}</label>
          <input type="number" class="preco-input w-full px-3 py-2 border rounded-lg text-center font-semibold"
            data-dia="${p.dia_semana}" value="${p.preco}" step="0.01" />
        </div>
      `).join('')
    } catch {
      window.showToast('❌ Erro ao carregar preços', false)
    }
  }

  document.getElementById('salvar-precos-btn').addEventListener('click', async () => {
    try {
      const inputs = document.querySelectorAll('.preco-input')
      for (const input of inputs) {
        await db.precos.atualizar(Number(input.dataset.dia), Number(input.value))
      }
      window.showToast('✅ Preços atualizados!')
    } catch {
      window.showToast('❌ Erro ao salvar', false)
    }
  })

  async function loadDatasEspeciais() {
    try {
      const datas = await db.datasEspeciais.listar()
      const tbody = document.getElementById('datas-especiais-tbody')
      if (datas.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">Nenhuma data especial.</td></tr>'
        return
      }
      tbody.innerHTML = datas.map(d => `
        <tr class="border-t border-gray-50 hover:bg-gray-50">
          <td class="px-4 py-3">${formatarData(d.data)}</td>
          <td class="px-4 py-3">${d.label}</td>
          <td class="px-4 py-3">${formatarPreco(d.preco)}</td>
          <td class="px-4 py-3">${d.recorrente ? '✅' : '—'}</td>
          <td class="px-4 py-3">
            <button onclick="window.removerDataEspecial('${d.id}')" class="p-1 hover:bg-red-50 rounded text-red-500">🗑️</button>
          </td>
        </tr>
      `).join('')
    } catch {
      window.showToast('❌ Erro ao carregar datas especiais', false)
    }
  }

  document.getElementById('add-data-especial-btn').addEventListener('click', () => {
    document.getElementById('form-data-especial').reset()
    document.getElementById('modal-data-especial').classList.remove('hidden')
  })

  document.getElementById('modal-de-cancel').addEventListener('click', () => {
    document.getElementById('modal-data-especial').classList.add('hidden')
  })

  document.getElementById('form-data-especial').addEventListener('submit', async (e) => {
    e.preventDefault()
    try {
      await db.datasEspeciais.adicionar({
        data: document.getElementById('de-data').value,
        label: document.getElementById('de-label').value,
        preco: Number(document.getElementById('de-preco').value),
        recorrente: document.getElementById('de-recorrente').checked
      })
      document.getElementById('modal-data-especial').classList.add('hidden')
      window.showToast('✅ Data especial adicionada!')
      await loadDatasEspeciais()
    } catch {
      window.showToast('❌ Erro ao salvar', false)
    }
  })

  window.removerDataEspecial = async function(id) {
    if (!confirm('Remover esta data especial?')) return
    try {
      await db.datasEspeciais.remover(id)
      window.showToast('✅ Data removida!')
      await loadDatasEspeciais()
    } catch {
      window.showToast('❌ Erro ao remover', false)
    }
  }

  loadPrecos()
  loadDatasEspeciais()
</script>
