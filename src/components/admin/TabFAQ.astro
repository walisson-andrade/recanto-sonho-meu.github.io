<div class="admin-tab-panel hidden" data-tab="faq">
  <div class="flex justify-end mb-6">
    <button id="add-faq-btn" class="bg-verde text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-verde-claro">
      + Adicionar
    </button>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-left">
        <tr>
          <th class="px-4 py-3 font-medium text-gray-500 w-8"></th>
          <th class="px-4 py-3 font-medium text-gray-500">Pergunta</th>
          <th class="px-4 py-3 font-medium text-gray-500">Resposta</th>
          <th class="px-4 py-3 font-medium text-gray-500">Ativo</th>
          <th class="px-4 py-3 font-medium text-gray-500">Ações</th>
        </tr>
      </thead>
      <tbody id="faq-admin-tbody">
        <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">Carregando...</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Modal -->
  <div id="modal-faq" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 hidden">
    <div class="bg-white rounded-2xl p-6 max-w-md w-full mx-4 shadow-2xl">
      <h3 id="modal-faq-title" class="font-display text-xl font-bold text-verde mb-4">Nova Pergunta</h3>
      <form id="form-faq" class="space-y-4">
        <input type="hidden" id="faq-id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Pergunta *</label>
          <input type="text" id="faq-pergunta" required class="w-full min-w-0 px-3 py-2 border rounded-lg box-border" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Resposta *</label>
          <textarea id="faq-resposta" required rows="3" class="w-full px-3 py-2 border rounded-lg resize-none"></textarea>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="modal-faq-cancel" class="flex-1 py-2 rounded-lg border border-gray-300 hover:bg-gray-50">Cancelar</button>
          <button type="submit" class="flex-1 py-2 rounded-lg bg-verde text-white font-semibold hover:bg-verde-claro">Salvar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  import { db } from '../../lib/supabase.js'
  import { esc } from '../../lib/helpers.js'

  let faqItems = []

  async function loadFaq() {
    try {
      faqItems = await db.faq.listar()
    } catch { faqItems = [] }
    renderFaq()
  }

  function renderFaq() {
    const tbody = document.getElementById('faq-admin-tbody')
    if (faqItems.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">Nenhuma pergunta.</td></tr>'
      return
    }
    tbody.innerHTML = faqItems.map(f => `
      <tr class="border-t border-gray-50 hover:bg-gray-50" draggable="true" data-id="${f.id}">
        <td class="px-4 py-3 cursor-grab text-gray-300">⋮⋮</td>
        <td class="px-4 py-3 font-medium">${esc(f.pergunta)}</td>
        <td class="px-4 py-3 text-xs text-gray-500 max-w-xs truncate">${esc(f.resposta)}</td>
        <td class="px-4 py-3">
          <button onclick="window.toggleFaq('${f.id}', ${!f.ativo})"
            class="px-2 py-1 rounded text-xs font-medium ${f.ativo ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}">
            ${f.ativo ? 'Sim' : 'Não'}
          </button>
        </td>
        <td class="px-4 py-3">
          <div class="flex gap-1">
            <button onclick="window.editFaq('${f.id}')" class="p-1 hover:bg-blue-50 rounded text-blue-500">✏️</button>
            <button onclick="window.removerFaq('${f.id}')" class="p-1 hover:bg-red-50 rounded text-red-500">🗑️</button>
          </div>
        </td>
      </tr>
    `).join('')

    // Drag and drop
    let dragRow = null
    tbody.querySelectorAll('tr[draggable]').forEach(row => {
      row.addEventListener('dragstart', () => { dragRow = row; row.classList.add('opacity-50') })
      row.addEventListener('dragend', () => { row.classList.remove('opacity-50'); dragRow = null })
      row.addEventListener('dragover', (e) => { e.preventDefault(); row.classList.add('bg-verde/5') })
      row.addEventListener('dragleave', () => row.classList.remove('bg-verde/5'))
      row.addEventListener('drop', async (e) => {
        e.preventDefault()
        row.classList.remove('bg-verde/5')
        if (dragRow && dragRow !== row) {
          tbody.insertBefore(dragRow, row)
          const rows = [...tbody.querySelectorAll('tr[data-id]')]
          try {
            await db.faq.reordenar(rows.map((r, i) => ({ id: r.dataset.id, ordem: i })))
            await loadFaq()
          } catch { window.showToast('❌ Erro ao reordenar', false) }
        }
      })
    })
  }

  document.getElementById('add-faq-btn').addEventListener('click', () => {
    document.getElementById('modal-faq-title').textContent = 'Nova Pergunta'
    document.getElementById('form-faq').reset()
    document.getElementById('faq-id').value = ''
    document.getElementById('modal-faq').classList.remove('hidden')
  })

  document.getElementById('modal-faq-cancel').addEventListener('click', () => {
    document.getElementById('modal-faq').classList.add('hidden')
  })

  window.editFaq = function(id) {
    const f = faqItems.find(x => x.id === id)
    if (!f) return
    document.getElementById('modal-faq-title').textContent = 'Editar Pergunta'
    document.getElementById('faq-id').value = f.id
    document.getElementById('faq-pergunta').value = f.pergunta
    document.getElementById('faq-resposta').value = f.resposta
    document.getElementById('modal-faq').classList.remove('hidden')
  }

  document.getElementById('form-faq').addEventListener('submit', async (e) => {
    e.preventDefault()
    const id = document.getElementById('faq-id').value
    const dados = {
      pergunta: document.getElementById('faq-pergunta').value,
      resposta: document.getElementById('faq-resposta').value,
    }
    try {
      if (id) {
        await db.faq.atualizar(id, dados)
      } else {
        dados.ordem = faqItems.length
        dados.ativo = true
        await db.faq.adicionar(dados)
      }
      document.getElementById('modal-faq').classList.add('hidden')
      window.showToast('✅ FAQ salvo!')
      await loadFaq()
    } catch { window.showToast('❌ Erro ao salvar', false) }
  })

  window.toggleFaq = async function(id, ativo) {
    try {
      await db.faq.atualizar(id, { ativo })
      window.showToast(ativo ? '✅ Pergunta ativada' : '✅ Pergunta ocultada')
      await loadFaq()
    } catch { window.showToast('❌ Erro', false) }
  }

  window.removerFaq = async function(id) {
    if (!confirm('Remover esta pergunta?')) return
    try {
      await db.faq.remover(id)
      window.showToast('✅ Pergunta removida!')
      await loadFaq()
    } catch { window.showToast('❌ Erro ao remover', false) }
  }

  loadFaq()
</script>
